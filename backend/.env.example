# Server
PORT=4000
NODE_ENV=development

# Supabase (backend uses service role key for privileged ops; apps use anon key)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Anthropic — chat / summaries / prescription drafting
ANTHROPIC_API_KEY=

# OpenAI — Whisper for doctor voice-to-text during summary editing
OPENAI_API_KEY=

# AWS — Transcribe for in-room recording with speaker diarization
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_TRANSCRIBE_BUCKET=

# Misc
APP_BASE_URL=http://localhost:4000
